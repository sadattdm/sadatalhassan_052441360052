/* Unique Login Page Tweaks */

.login-box {
  max-width: 480px; /* Slimmer for better focus */
}

.label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.forgot-pass {
  font-size: 0.85rem;
  color: var(--mint);
  text-decoration: none;
  font-weight: 600;
}

.remember-me {
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 20px 0;
  font-size: 0.9rem;
  color: #64748b;
}

.remember-me input[type="checkbox"] {
  width: 18px;
  height: 18px;
  accent-color: var(--mint);
  cursor: pointer;
}

/* Add a nice entrance animation */
.login-box {
  animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
