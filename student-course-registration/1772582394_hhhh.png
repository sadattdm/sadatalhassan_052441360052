:root {
  --emerald: #065f46;
  --mint: #10b981;
  --mint-bg: #f0fdf4;
  --white: #ffffff;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: "Inter", sans-serif;
}

.auth-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8fafc;
  position: relative;
  overflow: hidden;
  padding: 20px;
}

/* Background Decoration */
.blob {
  position: absolute;
  width: 500px;
  height: 500px;
  background: var(--mint);
  filter: blur(100px);
  opacity: 0.1;
  z-index: 0;
  top: -100px;
  right: -100px;
}

/* Form Container */
.form-wrapper {
  position: relative;
  z-index: 1;
  background: var(--white);
  padding: 50px;
  border-radius: 32px;
  box-shadow: 0 25px 50px -12px rgba(6, 95, 70, 0.1);
  width: 100%;
  max-width: 700px;
  border: 1px solid rgba(16, 185, 129, 0.1);
}

.form-header {
  text-align: center;
  margin-bottom: 40px;
}

.back-link {
  display: inline-block;
  color: var(--mint);
  text-decoration: none;
  font-size: 0.9rem;
  font-weight: 600;
  margin-bottom: 20px;
}

.form-header h2 {
  font-size: 2rem;
  color: var(--emerald);
  letter-spacing: -1px;
}

.form-header p {
  color: #64748b;
  margin-top: 10px;
}

/* Grid Layout for Inputs */
.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-bottom: 30px;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.form-group label {
  font-size: 0.9rem;
  font-weight: 600;
  color: #334155;
}

.form-group input {
  padding: 14px 16px;
  border-radius: 12px;
  border: 1.5px solid #e2e8f0;
  font-size: 1rem;
  transition: all 0.3s ease;
  background: #fdfdfd;
}

.form-group input:focus {
  outline: none;
  border-color: var(--mint);
  box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
  background: #fff;
}

/* Custom File Upload */
input[type="file"] {
  font-size: 0.8rem;
  padding: 10px;
  background: var(--mint-bg);
  border: 1px dashed var(--mint);
  cursor: pointer;
}

/* Submit Button */
.btn-submit {
  width: 100%;
  padding: 16px;
  border-radius: 12px;
  border: none;
  background: var(--emerald);
  color: white;
  font-size: 1.1rem;
  font-weight: 700;
  cursor: pointer;
  transition:
    transform 0.2s,
    background 0.3s;
}

.btn-submit:hover {
  background: var(--mint);
  transform: translateY(-2px);
}

.form-footer {
  text-align: center;
  margin-top: 30px;
}

.form-footer a {
  color: var(--mint);
  text-decoration: none;
  font-weight: 700;
}

/* Responsive */
@media (max-width: 600px) {
  .form-grid {
    grid-template-columns: 1fr;
  }
  .form-wrapper {
    padding: 30px 20px;
  }
}
